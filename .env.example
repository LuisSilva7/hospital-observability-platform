# --- Base de dados (Docker Compose e backend) ---
POSTGRES_DB=hop
POSTGRES_USER=hop
POSTGRES_PASSWORD=hop
DB_URL=jdbc:postgresql://localhost:5432/hop

# --- Backend ---
SERVER_PORT=8080

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# --- LLM (necessário a partir do Módulo 8) ---
# fornecedor fixo (Anthropic) no MVP; trocar implica outra implementação de LlmProvider
LLM_API_KEY=
LLM_MODEL=claude-sonnet-5
# campos a remover dos payloads antes de enviar ao LLM (separados por vírgula), ex.: patientId,nif
LLM_REDACTED_FIELDS=

# --- n8n (necessário a partir do Módulo 7) ---
N8N_WEBHOOK_BASE_URL=http://localhost:5678

# --- Retenção ---
# dias a manter logs (os associados a alertas nunca são apagados); 0 = desativado
LOG_RETENTION_DAYS=30

# --- Ingestão ---
# máximo de logs por minuto por serviço; 0 = desativado
INGEST_RATE_LIMIT_PER_MINUTE=300

# --- Email (ação EMAIL das automações; opcional) ---
# sem SMTP_HOST o canal fica desativado e as automações EMAIL falham com aviso claro
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=hop@localhost
